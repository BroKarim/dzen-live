{
  "name": "oneurl",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "next dev",
    "dev:backend": "cd backend && pnpm run dev",
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm run dev:backend\"",
    "build": "PATH=\"/opt/homebrew/opt/node@22/bin:$PATH\" prisma generate && next build",
    "build:backend": "cd backend && pnpm run build",
    "start": "next start",
    "start:backend": "cd backend && pnpm run start",
    "db:push": "PATH=\"/opt/homebrew/opt/node@22/bin:$PATH\" prisma db push",
    "db:generate": "PATH=\"/opt/homebrew/opt/node@22/bin:$PATH\" prisma generate --no-hints",
    "db:migrate": "PATH=\"/opt/homebrew/opt/node@22/bin:$PATH\" prisma migrate dev",
    "db:studio": "PATH=\"/opt/homebrew/opt/node@22/bin:$PATH\" prisma studio",
    "lint": "eslint",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts --watch",
    "test:coverage": "vitest run --config vitest.config.mts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "test:e2e:ui": "playwright test --ui",
    "react-doctor": "react-doctor"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/s3-presigned-post": "^3.975.0",
    "@aws-sdk/s3-request-presigner": "^3.975.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@paper-design/shaders-react": "^0.0.76",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.2.0",
    "@prisma/engines": "^7.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.16",
    "@types/validator": "^13.15.10",
    "better-auth": "^1.4.9",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.27.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "prisma": "^7.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.5.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "validator": "^13.15.26",
    "zod": "^4.3.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@oxc-parser/binding-darwin-arm64": "0.135.0",
    "@oxlint/binding-darwin-arm64": "1.66.0",
    "@playwright/test": "^1.60.0",
    "@rolldown/binding-darwin-arm64": "^1.0.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "react-doctor": "0.7.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@prisma/client",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
